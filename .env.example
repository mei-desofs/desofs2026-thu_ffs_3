# Copiar para .env e preencher com valores reais (NÃO versionar o .env):
#   cp .env.example .env

# Password da base de dados PostgreSQL
POSTGRES_PASSWORD=changeme_local_dev

# Porto do PostgreSQL exposto no host (muda se já tiveres um Postgres no 5432)
DB_PORT=5434

# Porto da API exposto no host (muda se já tiveres algo no 8080)
API_PORT=8081

# Chave de assinatura JWT — TEM de ter >= 32 caracteres.
# Gerar uma forte com:  openssl rand -base64 48
JWT_SIGNING_KEY=replace_me_with_a_secure_key_min_32_chars
